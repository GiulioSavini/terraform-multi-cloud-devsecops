# ─── General ──────────────────────────────────────────────────
project     = "devsecops"
environment = "stg"

# ─── AWS ──────────────────────────────────────────────────────
aws_region                = "eu-west-1"
aws_vpc_cidr              = "10.10.0.0/16"
aws_eks_node_count        = 2
aws_eks_node_max_count    = 4
aws_eks_node_instance_type = "t3.large"

# ─── Azure ────────────────────────────────────────────────────
azure_subscription_id     = "00000000-0000-0000-0000-000000000000"
azure_location            = "westeurope"
azure_vnet_cidr           = "10.11.0.0/16"
azure_aks_node_count      = 2
azure_aks_node_max_count  = 4
azure_aks_node_vm_size    = "Standard_D2s_v3"

# ─── GCP ──────────────────────────────────────────────────────
gcp_project_id            = "my-gcp-project-id"
gcp_region                = "europe-west1"
gcp_vpc_cidr              = "10.12.0.0/16"
gcp_gke_node_count        = 2
gcp_gke_node_max_count    = 4
gcp_gke_node_machine_type = "e2-standard-2"

# ─── Shared Services ─────────────────────────────────────────
vault_replicas            = 3
monitoring_retention_days = 7
domain_name               = "stg.example.com"
letsencrypt_email         = "devops@example.com"
