# ─── General ──────────────────────────────────────────────────
project     = "devsecops"
environment = "dev"

# ─── AWS ──────────────────────────────────────────────────────
aws_region                = "eu-west-1"
aws_vpc_cidr              = "10.0.0.0/16"
aws_eks_node_count        = 1
aws_eks_node_max_count    = 2
aws_eks_node_instance_type = "t3.medium"

# ─── Azure ────────────────────────────────────────────────────
azure_subscription_id     = "00000000-0000-0000-0000-000000000000"
azure_location            = "westeurope"
azure_vnet_cidr           = "10.1.0.0/16"
azure_aks_node_count      = 1
azure_aks_node_max_count  = 2
azure_aks_node_vm_size    = "Standard_B2s"

# ─── GCP ──────────────────────────────────────────────────────
gcp_project_id            = "my-gcp-project-id"
gcp_region                = "europe-west1"
gcp_vpc_cidr              = "10.2.0.0/16"
gcp_gke_node_count        = 1
gcp_gke_node_max_count    = 2
gcp_gke_node_machine_type = "e2-medium"

# ─── Shared Services ─────────────────────────────────────────
vault_replicas            = 1
monitoring_retention_days = 3
domain_name               = "dev.example.com"
letsencrypt_email         = "devops@example.com"
