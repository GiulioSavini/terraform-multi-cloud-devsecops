# ─── General ──────────────────────────────────────────────────
project     = "devsecops"
environment = "prd"

# ─── AWS ──────────────────────────────────────────────────────
aws_region                = "eu-west-1"
aws_vpc_cidr              = "10.20.0.0/16"
aws_eks_node_count        = 3
aws_eks_node_max_count    = 10
aws_eks_node_instance_type = "m5.xlarge"

# ─── Azure ────────────────────────────────────────────────────
azure_subscription_id     = "00000000-0000-0000-0000-000000000000"
azure_location            = "westeurope"
azure_vnet_cidr           = "10.21.0.0/16"
azure_aks_node_count      = 3
azure_aks_node_max_count  = 10
azure_aks_node_vm_size    = "Standard_D4s_v3"

# ─── GCP ──────────────────────────────────────────────────────
gcp_project_id            = "my-gcp-project-id"
gcp_region                = "europe-west1"
gcp_vpc_cidr              = "10.22.0.0/16"
gcp_gke_node_count        = 3
gcp_gke_node_max_count    = 10
gcp_gke_node_machine_type = "e2-standard-4"

# ─── Shared Services ─────────────────────────────────────────
vault_replicas            = 5
monitoring_retention_days = 30
domain_name               = "example.com"
letsencrypt_email         = "devops@example.com"
